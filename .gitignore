# ====== 环境变量（含敏感信息）======
.env

# ====== Python 缓存 ======
__pycache__/
*.py[cod]
.Python
*.so
.pytest_cache/

# ====== 模型文件（体积巨大，需自行下载）======
models/**
!models/.gitkeep

# ====== BM25缓存（位于共享数据目录）======
backend/common/data/bm25_cache/

# ====== 大型知识库文件（PDF > 5MB）======
backend/common/data/study_abroad/schools/hongkong/*.pdf
backend/common/data/study_abroad/schools/australia/*.pdf
backend/common/data/study_abroad/schools/global/*.pdf
backend/common/data/study_abroad/schools/germany/*.pdf
backend/common/data/study_abroad/schools/singapore/*.pdf
backend/common/data/study_abroad/schools/usa/*.pdf
backend/common/data/study_abroad/scholarships/*.pdf

# ====== 日志 ======
logs/
backend/common/logs/
*.log

# ====== IDE / 系统文件 ======
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ====== 测试脚本 ======
tests/
test_*.py
scripts/test_*.py
judge_test/

# ====== 私有开发脚本（根目录下 _ 前缀）======
/_*.py

# ====== 文档 ======
docs/
*.md
!README.md

# ====== .trae 临时输出 ======
.trae/documents/
.trae/judge-output/
.trae/rules/*.md
.trae/skills/web-search-qwen/

# ====== 临时文件 ======
@*
*_交互文档.md
simple_server.py

# ====== 测试输出 ======
test_sse.txt
test_sse_output.txt
server_test.log
