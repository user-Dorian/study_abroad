# RAG系统环境变量配置示例
# 复制此文件为 .env 并填写实际值

# 环境配置 (development/production)
ENV=development

# 应用配置
APP_NAME=RAG系统
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# 服务器配置
HOST=0.0.0.0
PORT=8000

# AI API配置（两项至少配置一项）
DASHSCOPE_API_KEY=your-dashscope-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# 数据库配置（PostgreSQL）
DB_HOST=localhost
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=rag_db

# 数据库连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis配置（缓存问答对）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_TTL=3600
REDIS_KEY_PREFIX=qa:

# Milvus向量数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DATABASE_NAME=study_abroad_db
MILVUS_COLLECTION_NAME=study_abroad_vectors

# SSL配置 (Windows环境设为false避免证书问题)
SSL_VERIFY=false

# 本地模型路径（可选，默认从HuggingFace加载）
# EMBEDDING_MODEL_PATH=D:\path\to\bge-m3
# RERANKER_MODEL_PATH=D:\path\to\bge-reranker-v2-m3

# HuggingFace离线模式
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# 会话管理配置
CONVERSATION_MAX_HISTORY_TURNS=10
CONVERSATION_AUTO_TITLE_ENABLED=true
CONVERSATION_TITLE_MAX_LENGTH=20
CONVERSATION_DEFAULT_TITLE=新对话
CONVERSATION_MESSAGES_PAGE_SIZE=50

# Docker环境自动启动配置
# 设置为 true 时，系统启动会自动检测并尝试启动 Redis/PostgreSQL/Milvus 容器
# 设置为 false 时，需要手动启动Docker环境
AUTO_START_DOCKER_ENV=true
